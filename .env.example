# Public site origin — used for metadata canonical URLs, Open Graph, robots,
# and sitemap. Set this to the production domain (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# PostHog analytics + error tracking. Get the Project API key from
# PostHog → Settings → Project → Project API Key. Leave unset to disable
# analytics entirely (the app runs fine without it).
NEXT_PUBLIC_POSTHOG_KEY=
# US cloud: https://us.i.posthog.com  ·  EU cloud: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Analytics reviewer automation (scripts/analytics-reviewer) ---
# These are SECRETS used only by the scheduled reviewer, never by the website.
# Put real values in .env.local (gitignored), NOT here. No NEXT_PUBLIC_ prefix.
#
# PostHog Personal API key (phx_...) with Query Read + Error tracking read.
# Settings → Personal API keys. Different from the public phc_ key above.
POSTHOG_PERSONAL_API_KEY=
# Optional — auto-resolved from the personal key if omitted.
POSTHOG_PROJECT_ID=
# Linear personal API key (lin_api_...) and target team (name or key).
LINEAR_API_KEY=
LINEAR_TEAM=Portfolio
